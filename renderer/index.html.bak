<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sentinel Security Suite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body class="bg-black text-neutral-200 font-sans antialiased overflow-hidden">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <aside class="w-64 bg-black border-r border-neutral-800 flex flex-col">
            <div class="p-6 border-b border-neutral-800">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-black border border-neutral-700 rounded-lg flex items-center justify-center shadow-lg shadow-purple-500/20">
                        <i data-lucide="shield-check" class="w-6 h-6 pastel-purple"></i>
                    </div>
                    <div>
                        <h1 class="font-bold text-white tracking-tight">Sentinel</h1>
                        <p class="text-[10px] text-neutral-500 uppercase tracking-wider">Security Suite</p>
                    </div>
                </div>
            </div>

            <nav class="flex-1 p-4 space-y-1">
                <button onclick="showView('dashboard')" id="nav-dashboard" class="nav-item active w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                    <span class="font-medium">Dashboard</span>
                </button>
                <button onclick="showView('network')" id="nav-network" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="radar" class="w-5 h-5"></i>
                    <span>Network Scan</span>
                </button>
                <button onclick="showView('threats')" id="nav-threats" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="shield-alert" class="w-5 h-5"></i>
                    <span>Threats</span>
                    <span id="threat-badge" class="ml-auto bg-rose-500 text-white text-xs px-2 py-0.5 rounded-full hidden">0</span>
                </button>
                <button onclick="showView('network-threats')" id="nav-network-threats" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="globe" class="w-5 h-5"></i>
                    <span>Network Threats</span>
                </button>
                <button onclick="showView('vulns')" id="nav-vulns" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="bug" class="w-5 h-5"></i>
                    <span>Vulnerabilities</span>
                </button>
                <button onclick="showView('scanner')" id="nav-scanner" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="file-search" class="w-5 h-5"></i>
                    <span>File Scanner</span>
                </button>
                <button onclick="showView('quarantine')" id="nav-quarantine" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="archive" class="w-5 h-5"></i>
                    <span>Quarantine</span>
                    <span id="quarantine-badge" class="ml-auto bg-rose-500 text-white text-xs px-2 py-0.5 rounded-full hidden">0</span>
                </button>
                <button onclick="showView('scans')" id="nav-scans" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="scan-line" class="w-5 h-5"></i>
                    <span>Scans</span>
                </button>
                <button onclick="showView('license')" id="nav-license" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="key" class="w-5 h-5"></i>
                    <span>License</span>
                </button>
                <button onclick="showView('settings')" id="nav-settings" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl transition text-left">
                    <i data-lucide="settings" class="w-5 h-5"></i>
                    <span>Settings</span>
                </button>
            </nav>

            <div class="p-4 border-t border-neutral-800">
                <div class="bg-neutral-900/50 rounded-xl p-4">
                    <p class="text-xs text-neutral-400 mb-2">Protection Status</p>
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full pulse-dot"></span>
                        <span class="text-sm font-medium pastel-green">Active</span>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-w-0">
            <!-- Header -->
            <header class="h-16 bg-black/80 border-b border-neutral-800 flex items-center justify-between px-8 backdrop-blur-md">
                <h2 id="page-title" class="text-lg font-semibold text-white">Dashboard</h2>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-neutral-900 rounded-full border border-neutral-700">
                        <span class="w-2 h-2 bg-emerald-400 rounded-full"></span>
                        <span class="text-xs text-neutral-300">Engine Online</span>
                    </div>
                    <button class="p-2 text-neutral-400 hover:text-white transition">
                        <i data-lucide="bell" class="w-5 h-5"></i>
                    </button>
                </div>
            </header>

            <!-- Views -->
            <div class="flex-1 overflow-y-auto p-8" id="content-area">
                <!-- Dashboard -->
                <div id="view-dashboard" class="view space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <div class="glass-card rounded-2xl p-6 card-hover">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-neutral-400 text-sm font-medium">Protection</span>
                                <div class="p-2 bg-emerald-500/10 rounded-lg">
                                    <i data-lucide="shield-check" class="w-5 h-5 text-emerald-400"></i>
                                </div>
                            </div>
                            <div class="text-2xl font-bold text-white">Active</div>
                            <p class="text-xs text-emerald-400 mt-1">Real-time monitoring on</p>
                        </div>

                        <div class="glass-card rounded-2xl p-6 card-hover">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-neutral-400 text-sm font-medium">Threats Detected</span>
                                <div class="p-2 bg-rose-500/10 rounded-lg">
                                    <i data-lucide="shield-alert" class="w-5 h-5 text-rose-400"></i>
                                </div>
                            </div>
                            <div class="text-2xl font-bold text-white" id="dash-threats">0</div>
                            <p class="text-xs text-neutral-500 mt-1">Since baseline saved</p>
                        </div>

                        <div class="glass-card rounded-2xl p-6 card-hover">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-neutral-400 text-sm font-medium">Network Devices</span>
                                <div class="p-2 bg-blue-500/10 rounded-lg">
                                    <i data-lucide="monitor" class="w-5 h-5 text-blue-400"></i>
                                </div>
                            </div>
                            <div class="text-2xl font-bold text-white" id="dash-devices">--</div>
                            <p class="text-xs text-neutral-500 mt-1">Discovered on last scan</p>
                        </div>

                        <div class="glass-card rounded-2xl p-6 card-hover">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-neutral-400 text-sm font-medium">Last Scan</span>
                                <div class="p-2 bg-amber-500/10 rounded-lg">
                                    <i data-lucide="clock" class="w-5 h-5 text-amber-400"></i>
                                </div>
                            </div>
                            <div class="text-2xl font-bold text-white" id="dash-last-scan">Never</div>
                            <p class="text-xs text-neutral-500 mt-1">Network discovery</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="glass-card rounded-2xl p-6 lg:col-span-2">
                            <h3 class="text-lg font-semibold text-white mb-2">System Health</h3>
                            <p class="text-sm text-neutral-400 mb-6">Current resource usage on this machine</p>
                            <div class="space-y-5">
                                <div>
                                    <div class="flex justify-between text-sm mb-2">
                                        <span class="text-neutral-300">CPU Usage</span>
                                        <span class="text-white font-medium" id="dash-cpu">--%</span>
                                    </div>
                                    <div class="h-2 bg-neutral-700 rounded-full overflow-hidden">
                                        <div id="dash-cpu-bar" class="h-full bg-emerald-400 rounded-full transition-all" style="width: 0%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-2">
                                        <span class="text-neutral-300">Memory Usage</span>
                                        <span class="text-white font-medium" id="dash-memory">--%</span>
                                    </div>
                                    <div class="h-2 bg-neutral-700 rounded-full overflow-hidden">
                                        <div id="dash-memory-bar" class="h-full bg-blue-400 rounded-full transition-all" style="width: 0%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-2">
                                        <span class="text-neutral-300">Disk Usage</span>
                                        <span class="text-white font-medium" id="dash-disk">--%</span>
                                    </div>
                                    <div class="h-2 bg-neutral-700 rounded-full overflow-hidden">
                                        <div id="dash-disk-bar" class="h-full bg-amber-400 rounded-full transition-all" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card rounded-2xl p-6">
                            <h3 class="text-lg font-semibold text-white mb-4">Quick Actions</h3>
                            <div class="space-y-3">
                                <button onclick="showView('network'); runScan()" class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl text-sm font-medium transition flex items-center justify-center gap-2">
                                    <i data-lucide="scan-line" class="w-4 h-4"></i>
                                    Run Network Scan
                                </button>
                                <button onclick="showView('threats')" class="w-full py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl text-sm font-medium transition flex items-center justify-center gap-2">
                                    <i data-lucide="shield-alert" class="w-4 h-4"></i>
                                    View Threats
                                </button>
                                <button onclick="showView('settings')" class="w-full py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl text-sm font-medium transition flex items-center justify-center gap-2">
                                    <i data-lucide="settings" class="w-4 h-4"></i>
                                    Settings
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Product Modules -->
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <h3 class="text-lg font-semibold text-white">Endpoint Protection Modules</h3>
                            <span class="text-xs text-neutral-500">Select a module to configure</span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            <div class="module-card purple rounded-2xl p-6 cursor-pointer" onclick="showView('scanner')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-purple rounded-xl">
                                        <i data-lucide="shield" class="w-6 h-6 pastel-purple"></i>
                                    </div>
                                    <span class="text-xs text-emerald-400 font-medium">Active</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Next-Gen Antivirus</h4>
                                <p class="text-sm text-neutral-400">Protects against malware, ransomware, and sophisticated endpoint attacks.</p>
                            </div>

                            <div class="module-card blue rounded-2xl p-6 cursor-pointer" onclick="showView('network')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-blue rounded-xl">
                                        <i data-lucide="crosshair" class="w-6 h-6 pastel-blue"></i>
                                    </div>
                                    <span class="text-xs text-emerald-400 font-medium">Active</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Endpoint Detection & Response</h4>
                                <p class="text-sm text-neutral-400">Continuous monitoring, threat detection, and rapid response on every endpoint.</p>
                            </div>

                            <div class="module-card cyan rounded-2xl p-6 cursor-pointer" onclick="showView('network-threats')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-cyan rounded-xl">
                                        <i data-lucide="globe" class="w-6 h-6 pastel-cyan"></i>
                                    </div>
                                    <span class="text-xs text-emerald-400 font-medium">Active</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Threat Intelligence & Hunting</h4>
                                <p class="text-sm text-neutral-400">Cross-domain threat hunting powered by real-time feeds and IOC lookups.</p>
                            </div>

                            <div class="module-card orange rounded-2xl p-6 cursor-pointer" onclick="showView('scanner')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-orange rounded-xl">
                                        <i data-lucide="usb" class="w-6 h-6 pastel-orange"></i>
                                    </div>
                                    <span class="text-xs text-neutral-500 font-medium">Coming soon</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Device Control</h4>
                                <p class="text-sm text-neutral-400">Manage USB and peripheral device access to prevent data exfiltration.</p>
                            </div>

                            <div class="module-card pink rounded-2xl p-6 cursor-pointer" onclick="showView('network')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-pink rounded-xl">
                                        <i data-lucide="smartphone" class="w-6 h-6 pastel-pink"></i>
                                    </div>
                                    <span class="text-xs text-neutral-500 font-medium">Coming soon</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Mobile Device Protection</h4>
                                <p class="text-sm text-neutral-400">Extend visibility and protection to mobile endpoints and BYOD devices.</p>
                            </div>

                            <div class="module-card green rounded-2xl p-6 cursor-pointer" onclick="showView('network')">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="p-3 bg-pastel-green rounded-xl">
                                        <i data-lucide="network" class="w-6 h-6 pastel-green"></i>
                                    </div>
                                    <span class="text-xs text-neutral-500 font-medium">Coming soon</span>
                                </div>
                                <h4 class="text-base font-semibold text-white mb-1">Firewall Management</h4>
                                <p class="text-sm text-neutral-400">Centralized host firewall policy and network traffic control.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Network Scan -->
                <div id="view-network" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-6">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Network Discovery</h3>
                                <p class="text-sm text-neutral-400">Scan your local network for connected devices</p>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-sm text-neutral-400" id="network-subnet">Subnet: --</span>
                            </div>
                        </div>
                        <div class="flex flex-wrap items-end gap-4">
                            <div class="w-full md:w-64">
                                <label class="block text-xs text-neutral-400 mb-1">Subnet</label>
                                <input id="scan-subnet" type="text" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="10.0.0.0/24">
                            </div>
                            <div class="flex items-center gap-2 pb-2.5">
                                <input id="full-scan" type="checkbox" class="w-4 h-4 rounded border-neutral-600 bg-neutral-900 text-emerald-500 focus:ring-emerald-500">
                                <label for="full-scan" class="text-sm text-neutral-300">Full port scan</label>
                            </div>
                            <button onclick="runScan()" id="scan-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-6 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                <i data-lucide="play" class="w-4 h-4"></i>
                                Start Scan
                            </button>
                            <button onclick="saveBaseline()" id="baseline-btn" class="bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg px-6 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                <i data-lucide="save" class="w-4 h-4"></i>
                                Save Baseline
                            </button>
                        </div>
                        <div id="scan-status" class="mt-4 hidden"></div>
                    </div>

                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-semibold text-white">Discovered Devices</h3>
                            <span class="text-sm text-neutral-400" id="device-count">0 devices</span>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm">
                                <thead>
                                    <tr class="text-neutral-400 border-b border-neutral-700/50">
                                        <th class="pb-3 font-medium">IP Address</th>
                                        <th class="pb-3 font-medium">Hostname</th>
                                        <th class="pb-3 font-medium">Vendor</th>
                                        <th class="pb-3 font-medium">Open Ports</th>
                                        <th class="pb-3 font-medium">First Seen</th>
                                    </tr>
                                </thead>
                                <tbody id="devices-table" class="text-neutral-300"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Threats -->
                <div id="view-threats" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Security Alerts</h3>
                                <p class="text-sm text-neutral-400">New devices and changes detected since baseline</p>
                            </div>
                            <button onclick="loadAlerts()" class="px-3 py-1.5 bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg text-sm transition">Refresh</button>
                        </div>
                        <div id="alerts-list" class="space-y-2">
                            <p class="text-sm text-neutral-500">No alerts yet. Run a scan and save a baseline to detect changes.</p>
                        </div>
                    </div>
                </div>

                <!-- File Scanner -->
                <div id="view-scanner" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-6">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Malware Scanner</h3>
                                <p class="text-sm text-neutral-400">Scan files and directories for viruses, malware, and suspicious content</p>
                            </div>
                            <div class="flex items-center gap-2 px-3 py-1.5 bg-neutral-900 rounded-full border border-neutral-700">
                                <span class="text-xs text-neutral-300">ClamAV</span>
                                <span id="clamav-status" class="text-xs text-neutral-500">Checking...</span>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-end gap-3 mb-6">
                            <div class="w-full md:w-[24rem]">
                                <label class="block text-xs text-neutral-400 mb-1">Path</label>
                                <input id="scan-path" type="text" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="/path/to/file or /path/to/directory">
                            </div>
                            <button onclick="pickFile()" class="bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg px-4 py-2.5 text-sm font-medium transition flex items-center gap-2" title="Browse for file">
                                <i data-lucide="folder-open" class="w-4 h-4"></i>
                                File
                            </button>
                            <button onclick="pickDirectory()" class="bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg px-4 py-2.5 text-sm font-medium transition flex items-center gap-2" title="Browse for directory">
                                <i data-lucide="folder-tree" class="w-4 h-4"></i>
                                Folder
                            </button>
                            <button onclick="scanFile()" id="file-scan-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                <i data-lucide="file" class="w-4 h-4"></i>
                                Scan File
                            </button>
                            <button onclick="scanDirectory()" id="dir-scan-btn" class="bg-blue-600 hover:bg-blue-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                <i data-lucide="folder" class="w-4 h-4"></i>
                                Scan Directory
                            </button>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-neutral-900/50 rounded-xl">
                            <div>
                                <p class="text-sm font-medium text-white">Real-time Protection</p>
                                <p class="text-xs text-neutral-400">Monitor file system for threats</p>
                            </div>
                            <button onclick="toggleRealtime()" id="realtime-toggle" class="px-4 py-2 bg-neutral-700 text-white rounded-lg text-sm font-medium transition">
                                Start Protection
                            </button>
                        </div>

                        <div id="scanner-status" class="mt-4 hidden"></div>
                    </div>

                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-semibold text-white">Scan Results</h3>
                            <button onclick="loadThreatResults()" class="px-3 py-1.5 bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg text-sm transition">Refresh</button>
                        </div>
                        <div id="threat-results" class="space-y-2">
                            <p class="text-sm text-neutral-500">No threats detected yet.</p>
                        </div>
                    </div>
                </div>

                <!-- Quarantine -->
                <div id="view-quarantine" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white">Quarantine</h3>
                                <p class="text-sm text-neutral-400">Files isolated for safety</p>
                            </div>
                            <button onclick="loadQuarantine()" class="px-3 py-1.5 bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg text-sm transition">Refresh</button>
                        </div>
                        <div id="quarantine-list" class="space-y-2">
                            <p class="text-sm text-neutral-500">No quarantined files.</p>
                        </div>
                    </div>
                </div>

                <!-- Scans -->
                <div id="view-scans" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="text-lg font-semibold text-white mb-4">Scan History</h3>
                        <div class="space-y-3" id="scan-history">
                            <p class="text-sm text-neutral-500">Scan history will appear here after you run scans.</p>
                        </div>
                    </div>
                </div>

                <!-- Network Threats -->
                <div id="view-network-threats" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="mb-6">
                            <h3 class="text-lg font-semibold text-white">URL & Host Scanner</h3>
                            <p class="text-sm text-neutral-400">Check URLs, IPs, and domains against URLhaus and ThreatFox</p>
                        </div>

                        <div class="space-y-4 max-w-2xl">
                            <div>
                                <label class="block text-xs text-neutral-400 mb-1">URL</label>
                                <div class="flex gap-2">
                                    <input id="check-url-input" type="text" class="flex-1 bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="https://example.com/malware.zip">
                                    <button onclick="checkUrl()" id="check-url-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition">Check URL</button>
                                </div>
                            </div>

                            <div>
                                <label class="block text-xs text-neutral-400 mb-1">IP or Domain</label>
                                <div class="flex gap-2">
                                    <input id="check-host-input" type="text" class="flex-1 bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="192.168.1.1 or evil.com">
                                    <button onclick="checkHost()" id="check-host-btn" class="bg-blue-600 hover:bg-blue-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition">Check Host</button>
                                </div>
                            </div>
                        </div>

                        <div id="network-threat-status" class="mt-4 hidden"></div>
                    </div>

                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="text-lg font-semibold text-white mb-4">Network Threat Sources</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="p-4 bg-neutral-900/50 rounded-xl">
                                <p class="text-sm font-medium text-white">URLhaus</p>
                                <p class="text-xs text-neutral-400">Malware distribution sites and payloads</p>
                                <span class="text-xs text-emerald-400">Enabled</span>
                            </div>
                            <div class="p-4 bg-neutral-900/50 rounded-xl">
                                <p class="text-sm font-medium text-white">ThreatFox</p>
                                <p class="text-xs text-neutral-400">IOC database for IPs, domains, and file hashes</p>
                                <span class="text-xs text-emerald-400">Enabled</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vulnerabilities -->
                <div id="view-vulns" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <div class="mb-6">
                            <h3 class="text-lg font-semibold text-white">Vulnerability Scanner</h3>
                            <p class="text-sm text-neutral-400">Check software against CISA's Known Exploited Vulnerabilities catalog</p>
                        </div>

                        <div class="flex gap-2 mb-4 max-w-xl">
                            <input id="vuln-product-input" type="text" class="flex-1 bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="Product name, e.g. Chrome, Windows, Adobe">
                            <button onclick="checkVulns()" id="vuln-check-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition">Check</button>
                            <button onclick="checkRunningVulns()" id="vuln-running-btn" class="bg-blue-600 hover:bg-blue-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition">Scan Running Apps</button>
                        </div>

                        <button onclick="updateFeeds()" id="update-feeds-btn" class="bg-neutral-700 hover:bg-neutral-600 text-white rounded-lg px-4 py-2 text-sm font-medium transition mb-4">Update CISA Feed</button>
                        <p class="text-xs text-neutral-500 mb-4">Auto-updates every hour. <span id="feed-status-text">Checking schedule...</span></p>

                        <div id="vuln-results" class="space-y-2">
                            <p class="text-sm text-neutral-500">No vulnerability checks yet.</p>
                        </div>
                    </div>
                </div>

                <!-- License -->
                <div id="view-license" class="view hidden space-y-6">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <div class="glass-card rounded-2xl p-6 lg:col-span-2">
                            <div class="flex items-center justify-between mb-6">
                                <div>
                                    <h3 class="text-lg font-semibold text-white">License & Subscription</h3>
                                    <p class="text-sm text-neutral-400">Manage your Sentinel license, activation, and billing</p>
                                </div>
                                <span id="license-status-badge" class="px-3 py-1 rounded-full text-xs font-medium bg-neutral-700 text-neutral-300">Checking...</span>
                            </div>

                            <div class="space-y-6">
                                <div>
                                    <label class="block text-xs text-neutral-400 mb-1">License Key</label>
                                    <div class="flex gap-2">
                                        <input id="license-key-input" type="text" class="flex-1 bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm font-mono focus:outline-none focus:border-emerald-500" placeholder="XXXX-XXXX-XXXX-XXXX">
                                        <button onclick="saveLicenseKey()" class="bg-neutral-800 hover:bg-neutral-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition">Save</button>
                                    </div>
                                    <p id="license-key-display" class="text-sm text-neutral-500 mt-2 hidden"></p>
                                </div>

                                <div>
                                    <label class="block text-xs text-neutral-400 mb-1">License Server URL</label>
                                    <input id="license-server-input" type="text" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="http://127.0.0.1:5000">
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="p-4 bg-neutral-900/50 rounded-xl">
                                        <p class="text-xs text-neutral-400">Tier</p>
                                        <p id="license-tier" class="text-lg font-semibold text-white mt-1">--</p>
                                    </div>
                                    <div class="p-4 bg-neutral-900/50 rounded-xl">
                                        <p class="text-xs text-neutral-400">Expires</p>
                                        <p id="license-expires" class="text-lg font-semibold text-white mt-1">--</p>
                                    </div>
                                    <div class="p-4 bg-neutral-900/50 rounded-xl">
                                        <p class="text-xs text-neutral-400">Devices</p>
                                        <p id="license-devices" class="text-lg font-semibold text-white mt-1">--</p>
                                    </div>
                                    <div class="p-4 bg-neutral-900/50 rounded-xl">
                                        <p class="text-xs text-neutral-400">Activation Status</p>
                                        <p id="license-activated" class="text-lg font-semibold text-white mt-1">--</p>
                                    </div>
                                </div>

                                <div class="flex flex-wrap gap-3">
                                    <button onclick="activateLicense()" id="activate-license-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                        <i data-lucide="check-circle" class="w-4 h-4"></i>
                                        Activate
                                    </button>
                                    <button onclick="validateLicense()" class="bg-blue-600 hover:bg-blue-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                                        Validate
                                    </button>
                                    <button onclick="deactivateLicense()" class="bg-rose-600 hover:bg-rose-500 text-white rounded-lg px-5 py-2.5 text-sm font-medium transition flex items-center gap-2">
                                        <i data-lucide="x-circle" class="w-4 h-4"></i>
                                        Deactivate
                                    </button>
                                </div>
                            </div>

                            <div id="license-message" class="mt-4 hidden"></div>
                        </div>

                        <div class="space-y-6">
                            <div class="glass-card rounded-2xl p-6">
                                <h3 class="text-lg font-semibold text-white mb-4">Subscription</h3>
                                <p class="text-sm text-neutral-400 mb-4">Upgrade, manage, or cancel your subscription.</p>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-xs text-neutral-400 mb-1">Email</label>
                                        <input id="checkout-email" type="email" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="you@example.com">
                                    </div>
                                    <div>
                                        <label class="block text-xs text-neutral-400 mb-1">Tier</label>
                                        <select id="checkout-tier" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500">
                                            <option value="home">Home (1 device)</option>
                                            <option value="business">Business (5 devices)</option>
                                            <option value="enterprise">Enterprise (50 devices)</option>
                                        </select>
                                    </div>
                                    <button onclick="openCheckout()" class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl text-sm font-medium transition flex items-center justify-center gap-2">
                                        <i data-lucide="credit-card" class="w-4 h-4"></i>
                                        Buy / Upgrade
                                    </button>
                                    <div>
                                        <label class="block text-xs text-neutral-400 mb-1">Stripe Customer ID</label>
                                        <input id="customer-portal-id" type="text" class="w-full bg-neutral-900 border border-neutral-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-emerald-500" placeholder="cus_...">
                                    </div>
                                    <button onclick="openCustomerPortal()" class="w-full py-3 bg-neutral-800 hover:bg-neutral-700 text-white rounded-xl text-sm font-medium transition flex items-center justify-center gap-2">
                                        <i data-lucide="user-circle" class="w-4 h-4"></i>
                                        Manage Billing
                                    </button>
                                </div>
                            </div>

                            <div class="glass-card rounded-2xl p-6">
                                <h3 class="text-lg font-semibold text-white mb-4">Downloads</h3>
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between p-3 bg-neutral-900/50 rounded-xl">
                                        <div>
                                            <p class="text-sm font-medium text-white">Sentinel for macOS</p>
                                            <p class="text-xs text-neutral-400">Apple Silicon</p>
                                        </div>
                                        <button onclick="downloadApp('mac')" class="text-xs text-emerald-400 hover:text-emerald-300 font-medium">Download</button>
                                    </div>
                                    <div class="flex items-center justify-between p-3 bg-neutral-900/50 rounded-xl">
                                        <div>
                                            <p class="text-sm font-medium text-white">Sentinel for Windows</p>
                                            <p class="text-xs text-neutral-400">64-bit</p>
                                        </div>
                                        <button onclick="downloadApp('windows')" class="text-xs text-emerald-400 hover:text-emerald-300 font-medium">Download</button>
                                    </div>
                                    <div class="flex items-center justify-between p-3 bg-neutral-900/50 rounded-xl">
                                        <div>
                                            <p class="text-sm font-medium text-white">Sentinel for Linux</p>
                                            <p class="text-xs text-neutral-400">x86_64</p>
                                        </div>
                                        <button onclick="downloadApp('linux')" class="text-xs text-emerald-400 hover:text-emerald-300 font-medium">Download</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Settings -->
                <div id="view-settings" class="view hidden space-y-6">
                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="text-lg font-semibold text-white mb-6">Threat Intelligence Sources</h3>
                        <div class="space-y-5 max-w-xl">
                            <div class="p-4 bg-neutral-900/50 rounded-xl">
                                <div class="flex items-center justify-between mb-2">
                                    <p class="text-sm font-medium text-white">VirusTotal</p>
                                    <span id="vt-status" class="text-xs text-neutral-400">No API key</span>
                                </div>
                                <p class="text-xs text-neutral-400 mb-3">Lookup file hashes against 70+ antivirus engines.</p>
                                <div class="flex gap-2">
                                    <input id="vt-api-key" type="password" class="flex-1 bg-neutral-900 border border-neutral-700 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-emerald-500" placeholder="VirusTotal API key">
                                    <button onclick="saveVirusTotalKey()" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-4 py-2 text-sm font-medium transition">Save</button>
                                </div>
                            </div>

                            <div class="p-4 bg-neutral-900/50 rounded-xl">
                                <div class="flex items-center justify-between mb-2">
                                    <p class="text-sm font-medium text-white">MalwareBazaar</p>
                                    <span class="text-xs text-emerald-400">Enabled</span>
                                </div>
                                <p class="text-xs text-neutral-400">Lookup file hashes against the Abuse.ch malware database.</p>
                            </div>

                            <div class="p-4 bg-neutral-900/50 rounded-xl">
                                <div class="flex items-center justify-between mb-2">
                                    <p class="text-sm font-medium text-white">YARA Rules</p>
                                    <span id="yara-status" class="text-xs text-neutral-400">Checking...</span>
                                </div>
                                <p class="text-xs text-neutral-400 mb-3">Pattern matching with built-in rules and optional signature-base rule pack.</p>
                                <button onclick="downloadYaraRules()" id="yara-download-btn" class="bg-blue-600 hover:bg-blue-500 text-white rounded-lg px-4 py-2 text-sm font-medium transition">Download Signature-Base Rules</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="text-lg font-semibold text-white mb-6">Engine Settings</h3>
                        <div class="space-y-4 max-w-xl">
                            <div class="flex items-center justify-between py-3 border-b border-neutral-700/50">
                                <div>
                                    <p class="text-sm font-medium text-white">Automatic Scanning</p>
                                    <p class="text-xs text-neutral-400">Scan network every 15 minutes</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-neutral-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                                </label>
                            </div>
                            <div class="flex items-center justify-between py-3 border-b border-neutral-700/50">
                                <div>
                                    <p class="text-sm font-medium text-white">New Device Alerts</p>
                                    <p class="text-xs text-neutral-400">Notify when unknown devices join</p>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-neutral-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                                </label>
                            </div>
                            <div class="flex items-center justify-between py-3">
                                <div>
                                    <p class="text-sm font-medium text-white">Dark Mode</p>
                                    <p class="text-xs text-neutral-400">Always enabled in this version</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card rounded-2xl p-6">
                        <h3 class="text-lg font-semibold text-white mb-2">About</h3>
                        <p class="text-sm text-neutral-400">Sentinel Security Suite v1.0.0</p>
                        <p class="text-sm text-neutral-400 mt-1">Standalone network security engine built with Python and Electron.</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="app.js"></script>
</body>
</html>
